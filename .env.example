# App
ENVIRONMENT=development

# LLM (swap provider with one line)
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-sonnet-5
LLM_FALLBACK_MODEL=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Research / search
RESEARCH_SEARCH_MODE=native
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=

# Lead qualification (ICP = Ideal Customer Profile)
ICP_DESCRIPTION=A B2B software or technology company with 10-500 employees, based in North America or Europe.
ICP_MIN_SCORE_TO_DRAFT=60

# Our own company/offering (used to draft outreach emails that pitch something concrete)
COMPANY_DESCRIPTION=Our company builds a product our prospective customers would benefit from.

# Discovery (broad-query enumeration -> many candidate companies)
DISCOVERY_MAX_RESULTS=20
# Discovery's own search config -- independent of RESEARCH_SEARCH_MODE above
LEAD_SEARCH_MODE=native
LEAD_SEARCH_PROVIDER=tavily
LEAD_SEARCH_API_KEY=

# Outputs
EXPORTERS=excel
EXPORT_DIR=./out/leads
SLACK_WEBHOOK_URL=
SMTP_URL=
GMAIL_CREDENTIALS=

# Observability
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
N8N_ALERT_WEBHOOK_URL=

# Infra / API
DATABASE_URL=postgresql+psycopg://leads:leads@localhost:5432/leads
API_KEY=
RATE_LIMIT_PER_MIN=60
