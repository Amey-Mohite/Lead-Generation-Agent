{
  "name": "03 - Alerting",
  "nodes": [
    {
      "parameters": {
        "path": "alert",
        "httpMethod": "POST",
        "responseMode": "onReceived"
      },
      "id": "3a3a3a3a-0001-4000-8000-000000000001",
      "name": "Webhook - Receive Alert",
      "type": "n8n-nodes-base.webhook",
